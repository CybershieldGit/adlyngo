# Nginx config for admin.adlyngo.com (add inside the server { } block)
#
# aaPanel: Website -> admin.adlyngo.com -> Config

# Allow large video uploads through the API proxy
client_max_body_size 100M;

location /uploads/ {
    alias /www/wwwroot/uploads/;
    expires 30d;
    add_header Cache-Control "public, max-age=2592000, immutable";
    add_header X-Content-Type-Options nosniff;

    limit_except GET HEAD {
        deny all;
    }

    autoindex off;
    try_files $uri =404;
}

location / {
    proxy_pass http://127.0.0.1:3001;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Large uploads need longer timeouts (adjust port if your app differs)
    proxy_connect_timeout 300s;
    proxy_send_timeout 300s;
    proxy_read_timeout 300s;
    send_timeout 300s;
}
